{
  "name": "digdog",
  "displayName": "Digdog",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Nabin Dhakal <nabindhakal336@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
